generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyRole {
  OWNER
  ADMIN
  ESTIMATOR
  SALES
  VIEWER
}

enum ProjectStatus {
  LEAD
  INSPECTION
  PROCESSING
  READY_FOR_QUOTE
  QUOTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum CaptureSource {
  DRONE
  MANUAL
}

enum MeasurementType {
  AREA
  DISTANCE
  RIDGE
  HIP
  VALLEY
  EAVE
  RAKE
  PITCH
  FACET_COUNT
  WASTE_FACTOR
}

enum MeasurementUnit {
  SQFT
  FT
  DEGREES
  RATIO
  COUNT
  PERCENT
  SQUARES
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
}

enum ImageryType {
  DRONE
  ORTHOMOSAIC
  MODEL
  BEFORE
  AFTER
}

enum ProcessingStatus {
  UPLOADED
  QUEUED
  PROCESSING
  READY
  NEEDS_REVIEW
  FAILED
}

model User {
  id              String              @id @default(cuid())
  clerkUserId     String              @unique
  email           String              @unique
  firstName       String?
  lastName        String?
  imageUrl        String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  memberships     CompanyMembership[]
  createdProjects Project[]           @relation("CreatedProjects")
}

model Company {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  memberships CompanyMembership[]
  projects    Project[]
}

model CompanyMembership {
  id        String      @id @default(cuid())
  companyId String
  userId    String
  role      CompanyRole @default(VIEWER)
  createdAt DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

model Project {
  id            String        @id @default(cuid())
  companyId     String
  createdById   String
  name          String
  clientName    String
  clientEmail   String?
  clientPhone   String?
  status        ProjectStatus @default(LEAD)
  captureSource CaptureSource @default(MANUAL)
  addressLine1  String
  city          String
  province      String
  postalCode    String?
  country       String        @default("Canada")
  latitude      Float?
  longitude     Float?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("CreatedProjects", fields: [createdById], references: [id], onDelete: Restrict)
  sections     RoofSection[]
  measurements Measurement[]
  issues       RoofIssue[]
  photos       PhotoAsset[]
  imagery      ProjectImagery[]
  processingJobs ProcessingJob[]
  comparisons  RoofComparison[]
  proposals    Proposal[]
  modelMeasurements ModelMeasurement[]
  aiUsageEvents AiUsageEvent[]

  @@index([companyId, status])
  @@index([companyId, createdAt])
}

/**
 * One row per billable AI call. Backs the rate limiter (counts within a rolling
 * window) and doubles as the record of what AI actually costs per project.
 * Rows are only written after a call is allowed through.
 */
model AiUsageEvent {
  id        String   @id @default(cuid())
  projectId String
  // Clerk-backed User id. Kept as a plain indexed column rather than a relation
  // so the usage record survives a user being removed.
  userId    String
  kind      String // "chat" | "summary"
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Serve the two limiter queries: per-project rolling day, per-user burst.
  @@index([projectId, createdAt])
  @@index([userId, createdAt])
}

// An interactive measurement drawn directly on the 3D model (WebODM-style):
// distance / area / height polylines/polygons, or a point marker. Points are
// stored in the model's metre frame (z-up) so they re-render exactly and can be
// recomputed server-side (areas, lengths) for reports/estimates.
model ModelMeasurement {
  id         String   @id @default(cuid())
  projectId  String
  kind       String // "distance" | "area" | "height" | "marker"
  pointsJson Json // number[][], model metres (z-up)
  // Authoritative surface area (ft²) for auto-detected "area" facets, computed
  // server-side from the facet's triangles. The viewer trusts this instead of
  // recomputing from pointsJson, whose boundary loop can self-intersect on noisy
  // meshes and collapse to ~0. Null for hand-drawn/edited shapes (recompute those).
  areaSqft   Float?
  label      String?
  // Roofing role for distance lines that feed the estimate:
  // "ridge" | "hip" | "valley" | "eave" | "rake" (null = uncategorised / not a line).
  category   String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model RoofSection {
  id                String   @id @default(cuid())
  projectId         String
  label             String
  planeIndex        Int?
  pitchRatio        String?
  pitchDegrees      Float?
  projectedAreaSqft Float?
  surfaceAreaSqft   Float?
  ridgeLengthFt     Float?
  hipLengthFt       Float?
  valleyLengthFt    Float?
  eaveLengthFt      Float?
  rakeLengthFt      Float?
  // "auto"   = produced by mesh extraction (re-extract replaces these).
  // "manual" = drawn/entered by a user (re-extract must NOT touch these).
  // Nullable only for rows created before this column existed; backfilled on push.
  source            String?
  geometryJson      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  measurements Measurement[]

  @@index([projectId])
  @@index([projectId, source])
}

model Measurement {
  id            String          @id @default(cuid())
  projectId     String
  roofSectionId String?
  type          MeasurementType
  label         String
  unit          MeasurementUnit
  value         Float
  displayValue  String
  confidence    Float?
  source        CaptureSource   @default(MANUAL)
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roofSection RoofSection? @relation(fields: [roofSectionId], references: [id], onDelete: SetNull)

  @@index([projectId, type])
  @@index([roofSectionId])
}

model RoofIssue {
  id             String        @id @default(cuid())
  projectId      String
  title          String
  description    String?
  severity       IssueSeverity @default(MEDIUM)
  locationLabel  String?
  annotationJson Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  photos  PhotoAsset[]

  @@index([projectId, severity])
}

model PhotoAsset {
  id              String   @id @default(cuid())
  projectId       String
  roofIssueId     String?
  url             String
  fileName        String?
  contentType     String?
  locationTag     String?
  caption         String?
  annotationsJson Json?
  createdAt       DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roofIssue RoofIssue? @relation(fields: [roofIssueId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([roofIssueId])
}

model ProjectImagery {
  id              String           @id @default(cuid())
  projectId       String
  type            ImageryType
  status          ProcessingStatus @default(UPLOADED)
  url             String
  fileName        String?
  contentType     String?
  captureDate     DateTime?
  altitudeFt      Float?
  metadataJson    Json?
  extractedJson   Json?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  processingJobs ProcessingJob[]

  @@index([projectId, type])
  @@index([projectId, status])
}

model ProcessingJob {
  id             String           @id @default(cuid())
  projectId      String
  modelImageryId String?
  provider       String           @default("nodeodm")
  providerTaskId String?
  status         ProcessingStatus @default(QUEUED)
  progress       Float?
  quality        String           @default("standard")
  sourceImageIds Json?
  optionsJson    Json?
  outputsJson    Json?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  modelImagery ProjectImagery? @relation(fields: [modelImageryId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([provider, providerTaskId])
  @@index([modelImageryId])
}

model RoofComparison {
  id            String   @id @default(cuid())
  projectId     String
  beforeUrl     String?
  afterUrl      String?
  title         String
  summary       String?
  differencesJson Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Proposal {
  id          String         @id @default(cuid())
  projectId   String
  title       String
  status      ProposalStatus @default(DRAFT)
  totalAmount Float?
  pdfUrl      String?
  scopeOfWork String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}
