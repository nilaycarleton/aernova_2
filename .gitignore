# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local runtime data
.postgres-data/
nodeodm-data/
public/uploads/

# Claude Code local state (worktrees, local settings)
.claude/

# graphify knowledge-graph output (generated; contains absolute machine paths)
graphify-out/

# impeccable per-session hook cache (local state, not project source)
.impeccable/hook.cache.json

# impeccable's vendored copy for GitHub Copilot (2.3MB of tooling, reinstallable
# with `npx impeccable install`). PRODUCT.md / DESIGN.md / .impeccable/design.json
# are the checked-in design context; this is just the engine.
.github/skills/
.github/hooks/

# vercel
.vercel

# vercel-labs/agent-skills (installed via `npx skills add`, reinstallable)
.agents/
skills-lock.json

# typescript
*.tsbuildinfo
next-env.d.ts
