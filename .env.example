# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# --- Database --------------------------------------------------------------
# Local dev uses the bundled Postgres on port 5433 (see npm run db:start).
DATABASE_URL="postgresql://USER@localhost:5433/aernova"

# --- Auth (Clerk) ----------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Use the app's own branded pages instead of Clerk's hosted portal.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- AI (OpenAI) -----------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxx

# --- File storage ----------------------------------------------------------
# STORAGE_DRIVER=local (default) writes to public/uploads — fine for local dev
# and single-server deploys. For cloud/object storage set STORAGE_DRIVER=s3
# (works with AWS S3 or Cloudflare R2) plus the values below.
STORAGE_DRIVER=local
# S3_BUCKET=aernova-uploads
# S3_REGION=auto                # "auto" for Cloudflare R2; e.g. us-east-1 for AWS
# S3_ENDPOINT=                  # R2: https://<account>.r2.cloudflarestorage.com; leave blank for AWS
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# STORAGE_PUBLIC_BASE_URL=      # public/CDN base that serves the bucket, e.g. https://cdn.example.com

# --- Photogrammetry worker (NodeODM) --------------------------------------
# Without NODEODM_URL the app uses the built-in draft model package.
NODEODM_URL=
NODEODM_TOKEN=
# NODEODM_OPTIONS_JSON='[{"name":"dsm","value":true},{"name":"gltf","value":true}]'
